{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install && uv pip install --system --link-mode=copy -r requirements.txt",
  "buildCommand": "npm run vercel-build",
  "rewrites": [
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/:path+", "destination": "/index.html" },
    { "source": "/docs", "destination": "/index.html" },
    { "source": "/docs/:path+", "destination": "/index.html" },
    { "source": "/console", "destination": "/console/index.html" },
    { "source": "/console/", "destination": "/console/index.html" },
    { "source": "/console/:path+", "destination": "/console/index.html" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  }
}
