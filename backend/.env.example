# === Базовые настройки ===
APP_ENV=development
APP_NAME=Anomaly AI
DEBUG=false

# === Пути (относительно backend/) ===
MODEL_DIR=models
DATA_DIR=data
REPORTS_DIR=reports

# === База данных ===
# SQLite (dev): sqlite+aiosqlite:///./data/anomaly_ai.db
# Postgres (prod): postgresql+asyncpg://user:pass@host:5432/anomaly_ai
DATABASE_URL=sqlite+aiosqlite:///./data/anomaly_ai.db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5

# === Redis (опционально, нужен для кэша и rate-limit storage) ===
# REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# === Аутентификация ===
# В dev по умолчанию false — фронт работает в демо-режиме. В prod установите true.
AUTH_REQUIRED=false
# Сгенерируйте безопасное значение: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=please-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
API_KEY_PREFIX=aa_live

# Первый администратор (создаётся, если БД пуста)
BOOTSTRAP_ADMIN_EMAIL=admin@anomaly.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2026

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# === Rate limiting ===
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_PREDICT=60/minute

# === Наблюдаемость ===
LOG_LEVEL=INFO
LOG_JSON=false
METRICS_ENABLED=true
# SENTRY_DSN=

# === SIEM ===
# SIEM_WEBHOOK_URL=https://splunk.example.com/services/collector
SIEM_WEBHOOK_FORMAT=json
# SIEM_WEBHOOK_TOKEN=
SIEM_MIN_CONFIDENCE=0.85

# === ML ===
ML_DRIFT_WARNING_THRESHOLD=0.10
ML_DRIFT_CRITICAL_THRESHOLD=0.25
ML_EXPLAIN_TOP_FEATURES=10
