# `public/` is generated by `npm run vercel-build` at build time.
# Keep it ignored locally to avoid committing generated static artifacts.
public/
*.log
npm-debug.log*

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# ML artifacts — ignore ad-hoc trained blobs; demo models ship for zero-config Vercel deploy
backend/models/*.joblib
!backend/models/waf_payload_model.joblib
!backend/models/network_anomaly_model.joblib
!backend/models/.gitkeep

# Data (keep samples; ignore large dumps)
backend/data/raw/*
!backend/data/raw/.gitkeep
backend/data/processed/*
!backend/data/processed/.gitkeep
