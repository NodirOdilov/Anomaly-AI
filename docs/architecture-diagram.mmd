flowchart TB
    subgraph CLIENT["CLIENT TIER"]
        direction LR
        sensor["Edge Sensor"]
        console["Analyst Console"]
        sdk["CLI / SDK"]
    end

    nginx["Nginx"]

    subgraph GATEWAY["API GATEWAY · FastAPI"]
        direction LR
        mw["Middleware"]
        rest["REST API"]
        ws["WebSocket"]
    end

    subgraph DOMAIN["DOMAIN SERVICES"]
        direction LR
        auth["Auth"]
        waf_svc["WAF"]
        net_svc["Network"]
        drift_svc["Drift"]
        alert_svc["Alerts"]
        ti_svc["Threat Intel"]
    end

    subgraph STORAGE["PERSISTENCE"]
        direction LR
        pg[("PostgreSQL")]
        redis[("Redis")]
        fs[("Artifacts")]
    end

    subgraph OBS["OBSERVABILITY"]
        direction LR
        prom["Prometheus"]
        graf["Grafana"]
    end

    siem["SIEM"]

    sensor & console & sdk --> nginx --> mw --> rest
    rest --> DOMAIN
    auth --> pg & redis
    waf_svc & net_svc --> alert_svc
    alert_svc --> siem
    alert_svc -.-> ws -.-> console
    rest -.-> prom --> graf

    classDef cli fill:#082f49,stroke:#22d3ee,color:#e0f2fe
    classDef gw fill:#0c4a6e,stroke:#38bdf8,color:#e0f2fe
    classDef svc fill:#3b0764,stroke:#c084fc,color:#f5f3ff
    classDef store fill:#451a03,stroke:#f97316,color:#fff7ed
    classDef obs fill:#052e16,stroke:#22c55e,color:#f0fdf4

    class sensor,console,sdk cli
    class nginx,mw,rest,ws gw
    class auth,waf_svc,net_svc,drift_svc,alert_svc,ti_svc svc
    class pg,redis,fs store
    class prom,graf obs
